{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rootDirectory": "src/frontend",
    "headers": [
        {
            "source": "/sitemap.xml",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                },
                {
                    "key": "Content-Type",
                    "value": "application/xml"
                }
            ]
        }
    ]
}