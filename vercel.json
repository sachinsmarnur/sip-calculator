{
    "routes": [
        {
            "src": "/sitemap.xml",
            "headers": {
                "Cache-Control": "no-store, max-age=0",
                "Content-Type": "application/xml"
            },
            "dest": "/sitemap.xml"
        },
        {
            "src": "/robots.txt",
            "headers": {
                "Cache-Control": "no-store, max-age=0",
                "Content-Type": "text/plain"
            },
            "dest": "/robots.txt"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}